# GitHub token for higher rate limits (5000 req/h instead of 60 req/h)
# Create one at https://github.com/settings/tokens (no scopes needed)
#
# Production (Cloudflare Pages): set via `wrangler pages secret put GITHUB_TOKEN`
# Local dev: define here, picked up by nitro-cloudflare-dev / Nuxt runtimeConfig
GITHUB_TOKEN=
